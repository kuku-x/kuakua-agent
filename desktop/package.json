{
  "name": "kuakua-agent",
  "version": "0.1.0",
  "description": "专属行为感知AI夸夸Agent",
  "main": "dist/main/index.js",
  "author": "kuakua",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "vue-tsc --noEmit && electron-vite build",
    "preview": "vite preview",
    "electron:dev": "electron-vite dev",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.8.2",
    "chart.js": "^4.4.0",
    "pinia": "^2.1.0",
    "vue-chartjs": "^5.3.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "electron": "^41.3.0",
    "electron-builder": "^24.9.0",
    "electron-vite": "^3.1.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue": "^3.5.33",
    "vue-tsc": "^3.2.7"
  },
  "build": {
    "appId": "com.kuakua.app",
    "productName": "夸夸app",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "build/icon.png"
      },
      {
        "from": "build/icon.ico",
        "to": "build/icon.ico"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "portable",
      "sign": false
    }
  }
}
