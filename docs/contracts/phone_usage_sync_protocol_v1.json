{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kuakua-agent/contracts/phone_usage_sync_protocol_v1.json",
  "title": "PhoneUsageSyncProtocolV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "batch_id", "device_id", "events"],
  "properties": {
    "protocol_version": {
      "type": "string",
      "const": "1.0"
    },
    "batch_id": {
      "type": "string",
      "minLength": 1
    },
    "device_id": {
      "type": "string",
      "minLength": 1
    },
    "device_name": {
      "type": "string"
    },
    "sent_at": {
      "type": "integer",
      "minimum": 0
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["event_id", "app_package", "started_at", "ended_at", "duration_sec"],
        "properties": {
          "event_id": {
            "type": "string",
            "minLength": 1
          },
          "app_package": {
            "type": "string",
            "minLength": 1
          },
          "app_name": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "started_at": {
            "type": "integer",
            "minimum": 0
          },
          "ended_at": {
            "type": "integer",
            "minimum": 0
          },
          "duration_sec": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
