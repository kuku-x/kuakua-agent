<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - 治愈温馨风主题，固定浅色模式 -->
    <style name="Theme.KuakuaPhoneStats" parent="Theme.Material3.Light">
        <!-- Primary brand color - 陶土暖棕色 -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <!-- Secondary brand color - 浅棕色 -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/primary</item>
        <!-- Navigation bar color -->
        <item name="android:navigationBarColor">@color/background</item>
        <!-- Card background - 浅米白 -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <!-- Error colors -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <!-- Window background - 暖米白 -->
        <item name="android:colorBackground">@color/background</item>
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <!-- Button styles -->
        <item name="materialButtonStyle">@style/Widget.Kuakua.Button.Warm</item>
        <item name="materialCardViewStyle">@style/Widget.Kuakua.Card.Warm</item>
    </style>

    <!-- Custom button style - 圆润温暖风格 -->
    <style name="Widget.Kuakua.Button.Warm" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- Custom outlined button style -->
    <style name="Widget.Kuakua.Button.Warm.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="strokeColor">@color/primary</item>
    </style>

    <!-- Custom card style - 治愈暖色卡片 -->
    <style name="Widget.Kuakua.Card.Warm" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <!-- Warm gradient title bar style -->
    <style name="GradientTitleBar">
        <item name="android:background">@drawable/gradient_warm_titlebar</item>
        <item name="android:padding">16dp</item>
    </style>

    <!-- Text styles -->
    <style name="TextAppearance.Kuakua.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.Kuakua.Label" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
</resources>
